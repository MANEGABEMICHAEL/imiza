# Configuration API Mobile Money - Imiza Tumaini

# Mode de l'application
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Orange Money API Configuration
ORANGE_MERCHANT_KEY=votre_merchant_key_orange
ORANGE_API_KEY=votre_api_key_orange

# MPesa API Configuration  
MPESA_API_KEY=votre_api_key_mpesa
MPESA_PUBLIC_KEY=votre_public_key_mpesa

# Airtel Money API Configuration
AIRTEL_CLIENT_ID=votre_client_id_airtel
AIRTEL_CLIENT_SECRET=votre_client_secret_airtel

# Configuration Banque
BANK_API_KEY=votre_api_key_banque

# Sécurité
JWT_SECRET=votre_jwt_secret_pour_production
SESSION_TIMEOUT=300000

# Base de données (fichiers JSON pour le moment)
DATA_PATH=./data
