# Configuration Email pour Imiza Tumaini
# Copiez ce fichier en .env et remplissez avec vos vraies configurations

# Configuration du serveur
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Clés de chiffrement
ENCRYPTION_KEY=votre_cle_de_chiffrement_32_caracteres_minimum
JWT_SECRET=votre_secret_jwt_64_caracteres_minimum
SESSION_SECRET=votre_secret_session_64_caracteres_minimum

# Configuration CORS
ALLOWED_ORIGINS=http://localhost:3000,https://imizatumaini.cd

# Configuration Email SMTP (OBLIGATOIRE pour les notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-app
ADMIN_EMAIL=admin@imizatumaini.cd

# APIs Mobile Money (remplacez par vos vraies clés)
ORANGE_MERCHANT_KEY=vraie_merchant_key_orange
ORANGE_API_KEY=vraie_api_key_orange

MPESA_API_KEY=vraie_api_key_mpesa
MPESA_PUBLIC_KEY=vraie_public_key_mpesa

AIRTEL_CLIENT_ID=vraie_client_id_airtel
AIRTEL_CLIENT_SECRET=vraie_client_secret_airtel

# URLs de callback
ORANGE_CALLBACK_URL=http://localhost:3000/payment/orange/notif
MPESA_CALLBACK_URL=http://localhost:3000/payment/mpesa/callback
AIRTEL_CALLBACK_URL=http://localhost:3000/payment/airtel/callback

# Limites de sécurité
MAX_DONATION_AMOUNT=5000
MIN_DONATION_AMOUNT=1
MAX_DONATIONS_PER_HOUR=10
MAX_REQUESTS_PER_15MIN=100
